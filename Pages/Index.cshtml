@page
<!-- Linking the ViewAlbums class to the HTML File -->
@model Project.Pages.ViewAlbums
<!DOCTYPE html>
<html lang="en">
    <head>
        <script src="/javascript/toggle_theme.js"></script>
        <link rel="stylesheet" href="css/material_design.css">
        <link rel="stylesheet" href="css/styles.css">
        <link rel="stylesheet" href="css/index.css">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="View all albums currently within the Chinook Database">
        <title>Chinook Console</title>
    </head>

    <body>

        <header id="header">
            <a href="/Index">
                <div id="logo">
                    <img id="logo_image" src="/images/website_icon.webp" alt="Web Logo">
                    <h1 class="not_important">Chinook Console</h1>
                </div>
            </a>

            <nav>
                <ul>
                    <li class="not_important"><a class="button button_header selected" href="/Index">Home</a></li>
                    <li><a class="button button_header" href="/Insert/AddArtistAlbum">Add Album</a></li>
                    <li><img id="theme_toggle" src="/images/ui/dark_mode.webp" alt="Theme Toggle" onclick="toggleTheme()"></li>
                </ul>
            </nav>
        </header>

        <main>
            <h2>@Model.Heading</h2> <!-- Displays the page the user is on -->
            <search>
                <form action="~/Search/Search" method="post" style="display: flex;">
                    @Html.AntiForgeryToken()

                        <!-- Outline Text Box to input Artist Name -->
                        <div style="width: 100%;" class="input">
                            <input class="text_box" type="text" id="tbxSearch" name="tbxSearch" placeholder=" " required>
                            <label for="tbxSearch">Search</label>
                        </div>

                        <!-- Button to add the Artist -->
                        <input class="search_button" type="submit" value="Go"/>
                    </form>
            </search>

            <section>
                <form action="~/Index" method="post" style="display: flex;">
                    @Html.AntiForgeryToken()

                    <select name="ddmSort">
                        <option value="0">Artist A-Z</option>
                        <option value="1">Artist Z-A</option>
                        <option value="2">Albums A-Z</option>
                        <option value="3">Albums Z-A</option>
                    </select>

                        <!-- Button to add the Artist -->
                        <input class="search_button" type="submit" value="Go"/>
                    </form>
            </section>
        

            <article class="card">
                <div class="card_header">
                    <img id="question_img" src="/images/album_cover_array.jpg">
                    <h3 id="sub_heading">Chinook Console</h3>
                    <h2 id="Title">Viewing All Albums</h2>
                </div>
                    <ul>
                        @foreach (ArtistAlbum album in @Model.ArtistAlbums){
                            <li class="answer_bar">
                                <form action="~/Details" method="post">
                                @Html.AntiForgeryToken()
                                    <input type="hidden" name="hdnAlbumID" value="@album.AlbumId"/>
                                    <button class="form_button" type="submit">
                                        <img id="btn_img_one" src="/images/cd_box.jpg">
                                        <h3>@album.Title</h3>
                                        <p>@album.Name</p>
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>
                </form>

            </article>

        </main>

        <footer>
            <p>Copyright &copy; 2026 Uniq Studio.</p>
            <p>B00869530</p>
            <p>Developed By Aaron Hamilton</p>
        </footer>

    </body>
</html>