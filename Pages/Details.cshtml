@page
<!-- Linking the ViewTracks class to the HTML File -->
@model Project.Pages.ViewTracks
<!DOCTYPE html>
<html lang="en">
    <head>
        <script src="/javascript/toggle_theme.js"></script>
        <script src="/javascript/confirmation.js"></script>
        <script src="/javascript/expand_window.js"></script>
        <link rel="stylesheet" href="/css/material_design.css">
        <link rel="stylesheet" href="/css/styles.css">
        <link rel="stylesheet" href="/css/details.css">
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="View all albums currently within the Chinook Database">
        <title>Chinook Console</title>
    </head>

    <body>
        <header id="header">
            <a href="/Index">
                <div id="logo">
                    <img id="logo_image" src="/images/website_icon.webp" alt="Web Logo">
                    <h1 class="not_important">Chinook Console</h1>
                </div>
            </a>

            <nav>
                <ul>
                    <li class="not_important"><a class="button button_header" href="/Index">Home</a></li>
                    <li><a class="button button_header" href="/Insert/AddArtistAlbum">Add Album</a></li>
                    <li><img id="theme_toggle" src="/images/ui/dark_mode.webp" alt="Theme Toggle" onclick="toggleTheme()"></li>
                </ul>
            </nav>
        </header>

        <main>
            <h2>@Model.Heading</h2> <!-- Displays the page the user is on -->
            <h3>@Model.AlbumName</h3>

            <!-- Creating a Numbered (Orgenised) List -->
            <ol>
                @foreach (AlbumTrack track in @Model.AlbumTrack){
                    //Displays each Track name
                    <li><p class="track_name">@track.Name</p></li>
                    <!-- Displays the Composer, Length (converting the ms into minutes, then removing as many 60s from the ms to get the remaining seconds - to crudly explain the use of %), Size and Price of each track -->
                    <p class="metadata">@track.Composer | @((track.Milliseconds / 1000) / 60):@((track.Milliseconds / 1000) % 60) | @(track.Bytes / 1048576) MB | £@track.UnitPrice</p>
                }
            </ol>

            <section class="modify_data" id="modify_window">

                <!-- Title bar of the window -->
                <section class="modify_title_bar" onclick="open_window()">
                    <h3>Modifiy Data</h3>
                    <p class="metadata">Click here to open.</p>
                </section>



                <!-- Adding Data Section -->
                <div style="display:flex; margin-bottom:15px; ">
                    <article class="left_side">
                        <h3>Add Track</h3>

                        <form action="~/Insert/InsertTrack" method="post">
                            @Html.AntiForgeryToken()
                            <div class="input">
                                <input class="text_box" type="text" id="tbxTrackName" name="tbxTrackName" placeholder=" " required>
                                <label for="tbxTrackName">Track Name:</label>
                            </div>                                                                                          <!-- Tracks Name, Requires input to prevent it being NULL -->
                            <p>Media Type:
                                <select name="ddmMedia" required>
                                    @foreach (MediaType media in @Model.MediaTypes){
                                        <option value="@media.MediaTypeId">@media.Name</option>
                                    }
                                </select>
                            </p>                                                                                            <!-- Media Type, Populated drop down menu to prevent it being NULL -->
                            <p>Genre Type:
                                <select style="max-width=100px" name="ddmGenre" required>
                                    @foreach (Genre genres in @Model.Genres){
                                        <option value="@genres.GenreId">@genres.Name</option>
                                    }
                                </select>
                            </p>                                                                                            <!-- Genre Type, Populated drop down menu to prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="text" id="tbxComposerName" name="tbxComposerName" placeholder=" ">
                                <label for="tbxComposerName">Composer:</label>
                            </div>                                                                                          <!-- Composer, Can be NULL -->
                            <div style="display:flex; width:150px;">
                                <div class="input">
                                    <input class="text_box" type="number" id="tbxMinuteName" name="tbxMinuteName" placeholder=" " required>
                                    <label for="tbxMinuteName">MM</label>
                                </div>
                                <p>:</p>
                                <div class="input">
                                    <input class="text_box" type="number" id="tbxSecondName" name="tbxSecondName" placeholder=" " required>
                                    <label for="tbxSecondName">SS</label>
                                </div>
                            </div>                                                                                          <!-- Length in Milliseconds, Requires input and set to number to prevent incompatible types and prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="number" id="tbxSizeName" name="tbxSizeName" placeholder=" " required>
                                <label for="tbxSizeName">Size (MB):</label>
                            </div>                                                                                          <!-- File Size, Requires input and set to number to prevent incompatible types and prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="number" step="0.01" min="0.49" id="tbxPriceName" name="tbxPriceName" placeholder=" " required>
                                <label for="tbxPriceName">Price: £</label>
                            </div>                                                                                          <!-- Price, Requires input and set to number to prevent incompatible types and prevent it being NULL and set to incriment by 1p (0.01) -->
                            <input type="hidden" name="hdnAlbumID" value="@Model._Album.AlbumId"/>                          <!-- AlbumId, Hidden from user prevent it being NULL and adds data to the correct album -->
                            <input class="button" type="submit" value="Insert"/>                                            <!-- Submits the form to add to the Database -->
                        </form>
                    </article>

                    


                    <article class="right_side">
                        <h3>Add Artist</h3>

                        <form action="~/Insert/InsertArtist" method="post">
                        @Html.AntiForgeryToken()
                            <div class="input">
                                <input class="text_box" type="text" id="tbxArtistName" name="tbxArtistName" placeholder=" " required>
                                <label for="tbxArtistName">Artist Name:</label>
                            </div>
                            <input class="button" type="submit" value="Insert"/> <!-- Submits the form to add Artist to the Database -->
                        </form>
                    </article>
                </div>



                <!-- Updating Data Section -->
                <div style="display:flex; margin-bottom:15px; ">
                    
                    <article class="left_side">
                        <h3>Update Track</h3>
                        <form action="~/Update/UpdateTrack" method="post">
                            @Html.AntiForgeryToken()
                            <p>Select Track:
                                <select name="ddmSelTrack" required>
                                    @foreach (AlbumTrack track in @Model.AlbumTrack){
                                        <option value="@track.TrackId">@track.Name</option>
                                    }
                                </select>                          
                            </p>                                                                                            <!-- Select Tracks, Set Range of Tracks in the album to help prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="text" id="tbxUpdateTrackName" name="tbxUpdateTrackName" placeholder=" " required>
                                <label for="tbxUpdateTrackName">Track Name:</label>
                            </div>                                                                                          <!-- Tracks Name, Requires input to prevent it being NULL -->
                            <p>Album:
                                <select style="max-width: 200px; width: 100%;" name="ddmUpdateAlbum" required>
                                    @foreach (Album album in @Model.Albums){
                                        //For look looks for the Album and Selects it in the dropdown automatically
                                        if (album.AlbumId == Model._Album.AlbumId){
                                            <option value="@album.AlbumId" selected>@album.Title</option>
                                        } else {
                                            <option value="@album.AlbumId">@album.Title</option>
                                        }
                                    }
                                </select>
                            </p>                                                                                            <!-- Select Album, Set Range of Albums in the Database to help prevent it being NULL -->
                            <p>Media Type:
                                <select name="ddmUpdateMedia" required>
                                    @foreach (MediaType media in @Model.MediaTypes){
                                        <option value="@media.MediaTypeId">@media.Name</option>
                                    }
                                </select>
                            </p>                                                                                            <!-- Media Type, Populated drop down menu to prevent it being NULL -->
                            <p>Genre Type:
                                <select name="ddmUpdateGenre" required>

                                    @foreach (Genre genres in @Model.Genres){
                                        <option value="@genres.GenreId">@genres.Name</option>
                                    }
                                </select>
                            </p>                                                                                                    <!-- Genre Type, Populated drop down menu to prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="text" id="tbxUpdateComposerName" name="tbxUpdateComposerName" placeholder=" ">
                                <label for="tbxUpdateComposerName">Composer:</label>
                            </div>                                                                                          <!-- Composer, Can be NULL -->
                            <div style="display:flex; width:150px;">
                                <div class="input">
                                    <input class="text_box" type="number" id="tbxUpdateMinuteName" name="tbxUpdateMinuteName" placeholder=" " required>
                                    <label for="tbxUpdateMinuteName">MM</label>
                                </div>
                                <p>:</p>
                                <div class="input">
                                    <input class="text_box" type="number" id="tbxUpdateSecondName" name="tbxUpdateSecondName" placeholder=" " required>
                                    <label for="tbxUpdateSecondName">SS</label>
                                </div>
                            </div>                                                                                          <!-- Length in Milliseconds, Requires input and set to number to prevent incompatible types and prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="number" id="tbxUpdateSizeName" name="tbxUpdateSizeName" placeholder=" " required>
                                <label for="tbxUpdateSizeName">Size (MB):</label>
                            </div>                                                                                          <!-- File Size, Requires input and set to number to prevent incompatible types and prevent it being NULL -->
                            <div class="input">
                                <input class="text_box" type="number" step="0.01" min="0.49" id="tbxUpdatePriceName" name="tbxUpdatePriceName" placeholder=" " required>
                                <label for="tbxUpdatePriceName">Price: £</label>
                            </div>    <!-- Price, Requires input and set to number to prevent incompatible types and prevent it being NULL and set to incriment by 1p (0.01) -->
                            <input class="button" type="submit" value="Update Track"/>                                                             <!-- Submits the form to update the track to the Database -->
                        </form>
                    </article>


                    
                    <article class="right_side">
                        <h3>Update Album</h3>
                        <form action="~/Update/UpdateAlbum" method="post">
                            @Html.AntiForgeryToken()
                            <div class="input">
                                <input class="text_box" type="text" id="tbxNewAlbumName" name="tbxNewAlbumName" value="@Model._Album.Title" required>
                                <label for="tbxNewAlbumName">Album Name:</label>
                            </div>
                            <p>Artist: 
                                <select style="max-width: 200px; width: 100%;" name="ddmNewArtist">
                                    @foreach (Artist artist in @Model.Artists){
                                        //For loop looks for the Album and Selects it in the dropdown automatically
                                        if (artist.ArtistId == Model._Album.ArtistId){
                                            <option value="@artist.ArtistId" selected>@artist.Name</option>
                                        } else {
                                            <option value="@artist.ArtistId">@artist.Name</option>
                                        }
                                    }
                                </select>
                            </p>
                            <input type="hidden" name="hdnAlbumID" value="@Model._Album.AlbumId"/>
                            <input class="button" type="submit" value="Update Album Data"/>
                        </form>
                    </article>
                </div>




                <!-- Deleting Data Section -->
                <div style="display:flex; margin-bottom:15px; ">
                    
                    <article class="left_side">
                        <h3>Delete Track</h3>
                        <form action="~/Delete/DeleteTrack" method="post">
                            @Html.AntiForgeryToken()
                            <p>Select Track:
                                <select style="max-width: 200px; width: 100%;" name="ddmSelTrack" required>
                                    @foreach (AlbumTrack track in @Model.AlbumTrack){
                                        <option value="@track.TrackId">@track.Name</option>
                                    }
                                </select>
                            </p>
                            <p style="display: none;" id="delete_track_confirm">Are you sure?<br/>This cannot be undone!<input class="button" type="submit" value="Delete Track"/></p> <!-- Confirmation message and submit button, Hidden until the user clicks the delete button -->
                        </form>
                        <button id="delete_track" class="button" onclick="deleteTrackRequest()">Delete Track</button> <!-- Button to trigger the confirmation message, Seperated from the form to prevent accidental deletion -->
                    </article>




                    
                    <article class="right_side">
                        <h3>Delete Album</h3>
                        <button id="delete_album" class="button" onclick="deleteAlbumRequest()">Delete Album</button>
                        <form style="display: none;" id="delete_album_confirm" action="~/Delete/DeleteAlbum" method="post">
                            @Html.AntiForgeryToken()
                            <p>Watch out! Deleting an album will remove all the songs within the album as well.<br/>This cannot be undone!</p> <!-- Confirmation message and submit button, Hidden until the user clicks the delete button --> 
                            <input type="hidden" name="hdnAlbumID" value="@Model._Album.AlbumId"/>
                            <p>Are you sure you want to delete the Album? <input class="button" type="submit" value="Yes"/></p> <!-- Button to trigger the confirmation message, Seperated from the form to prevent accidental deletion -->
                        </form>
                    </article>

                    
                </div>
            </section>
        </main>

        <footer>
            <p>Copyright &copy; 2026 Uniq Studio.</p>
            <p>B00869530</p>
            <p>Developed By Aaron Hamilton</p>
        </footer>

    </body>
</html>